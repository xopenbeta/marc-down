{
  "name": "marc-down",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "icon": "tauri icon",
    "pack": "tauri build --bundles dmg",
    "dev:pc": "tauri dev",
    "tauri": "tauri",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path'),src=p.resolve('node_modules/@bruits/satteri-wasm32-wasi/satteri_napi.wasm32-wasi.wasm'),dst=p.resolve('node_modules/satteri/satteri_napi.wasm32-wasi.wasm');if(fs.existsSync(src)&&!fs.existsSync(dst))fs.symlinkSync(src,dst)\""
  },
  "dependencies": {
    "@bruits/satteri-wasm32-wasi": "^0.9.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "highlight.js": "^11.11.1",
    "jotai": "^2.20.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.16.0",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "micromark": "^4.0.2",
    "micromark-extension-gfm-strikethrough": "^2.1.0",
    "micromark-extension-math": "^3.1.0",
    "ogl": "^1.0.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "satteri": "^0.9.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.0",
    "mdast-util-from-markdown": "^2.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.10"
  }
}
