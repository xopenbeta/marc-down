{
  "$schema": "https://raw.githubusercontent.com/niceda/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "MarcDown",
  "version": "0.1.0",
  "identifier": "com.marcdown.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MarcDown",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "credentialless"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "MarcDown Contributors",
    "category": "Productivity",
    "shortDescription": "A lightweight split-view Markdown editor.",
    "longDescription": "MarcDown is a lightweight split-view Markdown editor focused on fast editing, clear structure navigation, and cross-file search for daily writing workflows.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "packaging/linux/MarcDown.desktop.hbs"
      },
      "rpm": {
        "desktopTemplate": "packaging/linux/MarcDown.desktop.hbs"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown"
      }
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
